# Slack App Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Working Directory Configuration
# Base directory for relative paths (e.g., /Users/username/Code/)
# If set, you can use "cwd project-name" instead of full paths
BASE_DIRECTORY=/Users/username/Code/

# Claude CLI Configuration
# Path to the claude CLI binary (defaults to "claude" in PATH)
# CLAUDE_CLI_PATH=claude

# Permission mode for the CLI:
# - "skip" (default): Use --dangerously-skip-permissions (no permission prompts)
# - "allowedTools": Use --allowedTools with ALLOWED_TOOLS list
# - "acceptEdits": Use --permission-mode acceptEdits
# - "default": Use Slack-based permission prompts via MCP server
PERMISSION_MODE=skip

# Allowed tools when PERMISSION_MODE=allowedTools
# ALLOWED_TOOLS=Bash,Read,Write,Edit,MultiEdit,Grep,Glob

# Claude model to use (optional, uses CLI default if not set)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum number of agentic turns (optional)
# MAX_TURNS=25

# Append to system prompt (optional)
# APPEND_SYSTEM_PROMPT=Always explain your reasoning before making changes.

# Development
# DEBUG=true

# Voice Configuration
# Enable voice message support (requires Whisper STT and Kokoro TTS services)
# VOICE_ENABLED=true

# Whisper STT endpoint (local service)
# VOICE_STT_ENDPOINT=http://127.0.0.1:2022/v1

# Kokoro TTS endpoint (local service)
# VOICE_TTS_ENDPOINT=http://127.0.0.1:8880/v1

# TTS voice selection
# VOICE_TTS_VOICE=af_sky

# TTS model
# VOICE_TTS_MODEL=kokoro

# Response mode: voice | text | both
# - voice: Respond with voice messages only
# - text: Respond with text only (transcription still shown)
# - both: Respond with both text and voice
# VOICE_RESPONSE_MODE=voice
